## 六、React 组件结构

优先函数组件 + Hooks，禁止 Class 组件。

### 固定顺序

```tsx
// import: React核心 → 第三方 → 本地组件 → 类型 → API/工具
import { useState, useEffect, useCallback, useMemo } from 'react'
import { useNavigate } from 'react-router-dom'
import Card from '@/components/Card.vue'
import type { Props, IUser } from './types'
import { getUser } from '@/api/user'

// Props 类型单独定义，不内联
interface Props { userId: string }

function UserCard({ userId }: Props) {
    // Hooks 顺序: useState → useNavigate → useMemo → useEffect → useCallback
    const [data, setData] = useState<IUser | null>(null)
    const navigate = useNavigate()
    const displayName = useMemo(() => data?.name || '匿名', [data])
    useEffect(() => { fetchData() }, [userId])
    const handleClick = useCallback(() => { navigate(`/user/${userId}`) }, [userId, navigate])
    return <div className="user-card" onClick={handleClick}>{displayName}</div>
}
export default UserCard
```

**规则**：
- `useState<IUser | null>(null)`：泛型在括号内，复杂类型加泛型
- `useEffect`：显式依赖数组，mount 用 `[]`
- `useCallback`：传子组件或作依赖的函数必须包裹
- `useMemo`：复杂计算结果缓存
- 事件命名：`handleClickEvent`（交互）/ `handleSubmit`（提交）
- 类名：`className`，kebab-case（BEM）

