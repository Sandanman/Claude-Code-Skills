## 十一、API 文件结构

```javascript
import { get, post, put, del } from '@/utils/axios'
const apiConfigs = [
    { name: 'getList', url: '/api/module/list', method: 'post' },
    { name: 'createItem', url: '/api/module/create', method: 'post' },
    { name: 'updateItem', url: '/api/module/update', method: 'post' },
    { name: 'deleteItem', url: '/api/module/delete', method: 'post' }
]
const api = {}
apiConfigs.forEach(({ name, url, method }) => {
    api[name] = (data, options = {}) => {
        switch (method) {
            case 'get': return get(url, data, options)
            case 'delete': return del(url, { ...options, params: data })
            case 'post': return post(url, data, options)
            case 'put': return put(url, data, options)
        }
    }
})
export default api
```

